{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/seed.ts",
    "seed:cms": "tsx src/seed-cms.ts",
    "repair:project-images": "tsx src/scripts/repair-project-images.ts",
    "backfill:compression": "tsx src/scripts/backfill-compression.ts",
    "compress:public-images": "tsx src/scripts/compress-public-images.ts",
    "generate:public-webp": "tsx src/scripts/generate-public-webp.ts",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@workspace/api-zod": "file:./packages/api-zod",
    "@workspace/db": "file:./packages/db",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.39.3",
    "express": "^5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9",
    "pino-http": "^10",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/sanitize-html": "^2.16.1",
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.19.3"
  }
}
